{
  "name": "comedor-bot-telegram",
  "version": "1.0.0",
  "private": true,
  "description": "Control de Charola UNCP desde Telegram",
  "main": "telegram-bot.js",
  "scripts": {
    "start": "node telegram-bot.js",
    "check": "node --check telegram-bot.js",
    "install:browsers": "playwright install chromium",
    "install:browsers:linux": "playwright install --with-deps chromium",
    "start:pm2": "pm2 start telegram-bot.js --name charola-tg"
  },
  "dependencies": {
    "express": "^4.21.2",
    "node-telegram-bot-api": "^0.66.0",
    "playwright": "^1.59.1"
  }
}
